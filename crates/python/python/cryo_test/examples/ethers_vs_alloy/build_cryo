#!/usr/bin/env bash
#
# Build one or more cryo binaries for cryo_test comparison runs.
#
# Configuration (all optional, override via environment):
#   CRYO_REPO        path to the cryo repository
#                    (default: the git repo this script lives in)
#   CRYO_ALLOY_REF   git ref to build as "alloy"  (default: main)
#   CRYO_ETHERS_REF  git ref to build as "ethers" (default: the pre-alloy
#                    -migration commit, kept for historical comparison)
#
# NOTE: this checks out refs in CRYO_REPO in place. Commit or stash any work in
# that repository before running.

set -e

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve the cryo repository. No paths are hard-coded; the default is the git
# repository this script is part of.
CRYO_REPO="${CRYO_REPO:-$(git -C "$ROOT_DIR" rev-parse --show-toplevel)}"

# Git refs to build, overridable via environment.
ALLOY_REF="${CRYO_ALLOY_REF:-main}"
ETHERS_REF="${CRYO_ETHERS_REF:-eba6192298e40add4d35d1587511d875f6d770e4}"

mkdir -p "$ROOT_DIR/bin" "$ROOT_DIR/build"

# parse inputs
BUILD_ALLOY=false
BUILD_ETHERS=false
ANY_FLAG_SET=false
while getopts "ae-:" opt; do
   case $opt in
       a) BUILD_ALLOY=true; ANY_FLAG_SET=true ;;
       e) BUILD_ETHERS=true; ANY_FLAG_SET=true ;;
       -)
           case "${OPTARG}" in
               alloy) BUILD_ALLOY=true; ANY_FLAG_SET=true ;;
               ethers) BUILD_ETHERS=true; ANY_FLAG_SET=true ;;
               *) echo "Invalid option: --${OPTARG}" >&2
                  echo "Usage: $0 [-a|--alloy] [-e|--ethers]" >&2
                  exit 1 ;;
           esac ;;
       *) echo "Usage: $0 [-a|--alloy] [-e|--ethers]" >&2
          exit 1 ;;
   esac
done
if [ "$ANY_FLAG_SET" = false ]; then
   BUILD_ALLOY=true
   BUILD_ETHERS=true
fi
echo "CRYO_REPO: $CRYO_REPO"
echo "BUILD_ALLOY: $BUILD_ALLOY"
echo "BUILD_ETHERS: $BUILD_ETHERS"

# build a named variant from a given git ref
build_variant() {
    local name="$1" ref="$2"
    echo ""
    echo "building cryo $name (ref: $ref)"
    git -C "$CRYO_REPO" checkout "$ref"
    cargo install \
        --path "$CRYO_REPO/crates/cli" \
        --root "$ROOT_DIR/build/$name"
    rm -f "$ROOT_DIR/bin/cryo_$name"
    ln -s "$ROOT_DIR/build/$name/bin/cryo" "$ROOT_DIR/bin/cryo_$name"
    echo "built cryo $name at: $ROOT_DIR/bin/cryo_$name"
}

if [ "$BUILD_ALLOY" = true ]; then
    build_variant alloy "$ALLOY_REF"
fi
if [ "$BUILD_ETHERS" = true ]; then
    build_variant ethers "$ETHERS_REF"
fi
