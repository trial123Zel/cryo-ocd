# cryo-ocd environment configuration
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must NEVER be committed. Do not put API keys, RPC URLs, or IP addresses in any
# tracked file. See docs/adr/0005-secret-handling.md.

# RPC endpoint cryo uses as its data source.
# cryo reads ETH_RPC_URL by default; the --rpc flag overrides it.
ETH_RPC_URL=http://localhost:8545

# RPC endpoint used by the cryo_test validation harness and the self-hosted
# CI runner. On the runner host this points at the local node.
RETH_RPC_URL=http://localhost:8545

# Optional: directory for cryo_test output and regression baselines.
# CRYO_TEST_DATA_DIR=./cryo_test_data
